# Database
DATABASE_URL=postgresql+psycopg://metricgraph:metricgraph@postgres:5432/metricgraph

# Redis / RQ
REDIS_URL=redis://redis:6379/0

# MinIO / S3
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=metricgraph
S3_REGION=us-east-1
S3_USE_SSL=false

# LLM via OpenRouter (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
OPENROUTER_SITE_URL=https://metricgraph.local
OPENROUTER_APP_NAME=MetricGraph

# Embeddings (optional - OpenRouter has NO embeddings endpoint).
# Provide an OpenAI-compatible embeddings key to enable semantic search.
# Leave EMBEDDING_API_KEY empty to fall back to keyword-only search.
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small

# App
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Integration hub (Slack/Teams/Linear bridge). Leave the URL empty to disable
# outbound event emission. The secret is sent as the X-Hub-Secret header.
INTEGRATION_WEBHOOK_URL=
INTEGRATION_WEBHOOK_SECRET=

# Optional Margin Catalog governance layer (same event envelope as integration hub)
GOVERNANCE_WEBHOOK_URL=
GOVERNANCE_WEBHOOK_SECRET=
