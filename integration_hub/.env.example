# Shared secret for inbound events from MetricGraph and ingest_engine.
# Senders include it as the `X-Hub-Secret` header.
HUB_WEBHOOK_SECRET=change-me

# MetricGraph REST API (used for inbound chat actions and Linear registry lookups).
METRICGRAPH_BASE_URL=http://localhost:8000

# --- Slack ---
# Bot token (xoxb-...) for chat.postMessage / chat.update.
SLACK_BOT_TOKEN=
# Signing secret used to verify slash commands and interactivity payloads.
SLACK_SIGNING_SECRET=
# Channel IDs (e.g. C0123ABCD) that the hub posts to per event class.
SLACK_ALERT_CHANNEL=
SLACK_INFO_CHANNEL=
SLACK_INGEST_CHANNEL=

# --- Microsoft Teams ---
# Incoming Webhook URL for outbound Adaptive Cards.
TEAMS_INCOMING_WEBHOOK_URL=
# Base64 HMAC secret from the Teams Outgoing Webhook (for inbound commands).
TEAMS_OUTGOING_WEBHOOK_SECRET=

# --- Linear ---
# Personal API key (lin_api_...) used for GraphQL issue + comment creation.
LINEAR_API_KEY=
# Webhook signing secret to verify inbound Linear events.
LINEAR_WEBHOOK_SECRET=
# Team ID that conflict issues are created in.
LINEAR_TEAM_ID=
# Bot/actor user ID whose own comments should be ignored to avoid reply loops.
LINEAR_BOT_USER_ID=

# --- Service ---
STATE_DB=./.hub_state.db
# Optional YAML overriding routing/channel defaults.
HUB_CONFIG_FILE=config.yaml
LOG_LEVEL=INFO
