# Root docker-compose environment (copy to .env at repo root).
# prev/ is intentionally excluded from the stack.

# Shared webhook secrets (MetricGraph → hub / catalog)
HUB_WEBHOOK_SECRET=change-me
CATALOG_WEBHOOK_SECRET=change-me
AUTH_SECRET=change-me-to-long-random-string

# Workspace API keys (mint via CLI — see DOCKER.md)
MARGIN_API_KEY=
INGEST_API_KEY=

# Ingest engine poll interval (seconds)
INGEST_POLL_INTERVAL=10

# Optional LLM + connector secrets
OPENROUTER_API_KEY=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
LINEAR_API_KEY=
LINEAR_WEBHOOK_SECRET=
LINEAR_TEAM_ID=

# Per-service .env files are optional when using root compose — secrets above
# are passed through to services directly.
